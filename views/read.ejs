<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>All Users</title>
    <script src="https://cdn.tailwindcss.com"></script>

    <script>
        tailwind.config = {
            theme: {
                extend: {
                    keyframes: {
                        fadeUp: {
                            "0%": { opacity: "0", transform: "translateY(20px)" },
                            "100%": { opacity: "1", transform: "translateY(0)" }
                        },
                        gradientMove: {
                            "0%,100%": { backgroundPosition: "0% 50%" },
                            "50%": { backgroundPosition: "100% 50%" }
                        }
                    },
                    animation: {
                        fadeUp: "fadeUp 0.8s ease-out forwards",
                        gradient: "gradientMove 12s ease infinite"
                    }
                }
            }
        }
    </script>
</head>

<body class="bg-zinc-950 text-white">

    <!-- Animated Background -->
    <div class="absolute inset-0 -z-10 bg-gradient-to-br from-blue-600/15 via-purple-600/15 to-pink-600/15 
                bg-[length:300%_300%] animate-gradient"></div>

    <div class="max-w-7xl mx-auto px-6 py-12">

        <a href="/" class="text-blue-400 hover:text-blue-300 transition">
            ← Back to Home
        </a>

        <h1 class="text-4xl font-semibold tracking-tight mt-6 mb-10">
            All Users
        </h1>

        <% if(users.length > 0){ %>
        <div class="users grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-8">
            <% users.forEach(function(user){ %>

            <!-- User Card -->
            <div class="group backdrop-blur-xl bg-zinc-900/70 border border-white/10 rounded-2xl p-4
                        shadow-lg hover:shadow-2xl transition-all duration-300 animate-fadeUp">

                <div class="w-full h-56 rounded-xl overflow-hidden">
                    <img
                        src="<%= user.image %>"
                        class="w-full h-full object-cover  mt-5 transition duration-500 group-hover:scale-110"
                        alt="<%= user.name %>"
                    >
                </div>

                <h3 class="text-xl font-medium tracking-tight mt-4">
                    <%= user.name %>
                </h3>

                <p class="text-sm text-zinc-400 mt-1 truncate">
                    <%= user.email %>
                </p>

                <div class="flex justify-between items-center mt-5 text-sm">
                    <a href="/edit/<%= user._id %>"
                       class="text-blue-400 hover:text-blue-300 transition">
                        Edit
                    </a>
                    <a href="/delete/<%= user._id %>"
                       class="text-red-500 hover:text-red-400 transition">
                        Delete
                    </a>
                </div>
            </div>

            <% }) %>
        </div>
        <% } else { %>

        <div class="text-zinc-400 text-lg mt-10">
            No users yet.
        </div>

        <% } %>

    </div>
</body>
</html>
