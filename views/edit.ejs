<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Update User</title>
    <script src="https://cdn.tailwindcss.com"></script>

    <script>
        tailwind.config = {
            theme: {
                extend: {
                    keyframes: {
                        fadeUp: {
                            "0%": { opacity: "0", transform: "translateY(24px)" },
                            "100%": { opacity: "1", transform: "translateY(0)" }
                        },
                        gradientMove: {
                            "0%,100%": { backgroundPosition: "0% 50%" },
                            "50%": { backgroundPosition: "100% 50%" }
                        }
                    },
                    animation: {
                        fadeUp: "fadeUp 0.8s ease-out forwards",
                        gradient: "gradientMove 12s ease infinite"
                    }
                }
            }
        }
    </script>
</head>

<body class="min-h-screen bg-zinc-950 text-white overflow-hidden">

    <!-- Animated Gradient Background -->
    <div class="absolute inset-0 -z-10 bg-gradient-to-br from-yellow-500/15 via-orange-500/15 to-amber-500/15 
                bg-[length:300%_300%] animate-gradient"></div>

    <div class="min-h-screen flex items-center justify-center px-4">

        <div class="w-full max-w-md backdrop-blur-2xl bg-zinc-900/70 border border-white/10 rounded-3xl p-10 
                    shadow-2xl animate-fadeUp">

            <a href="/read" class="text-sm text-yellow-400 hover:text-yellow-300 transition">
                ← Read Users
            </a>

            <h1 class="text-4xl font-semibold tracking-tight mt-6 mb-10">
                Update User
            </h1>

            <form action="/update/<%= users._id %>" method="post" class="space-y-8">

                <!-- Name -->
                <div class="relative">
                    <input
                        required
                        name="name"
                        type="text"
                        value="<%= users.name %>"
                        placeholder="Full Name"
                        class="peer w-full bg-transparent border-b border-white/20 py-3 text-white placeholder-transparent
                               focus:outline-none focus:border-yellow-400 transition"
                    >
                    <label class="absolute left-0 top-3 text-white/50 text-sm transition-all
                                  peer-placeholder-shown:top-3 peer-placeholder-shown:text-base peer-placeholder-shown:text-white/30
                                  peer-focus:-top-4 peer-focus:text-sm peer-focus:text-yellow-400
                                  peer-valid:-top-4 peer-valid:text-sm peer-valid:text-yellow-400">
                        Full Name
                    </label>
                </div>

                <!-- Email -->
                <div class="relative">
                    <input
                        required
                        name="email"
                        type="email"
                        value="<%= users.email %>"
                        placeholder="Email Address"
                        class="peer w-full bg-transparent border-b border-white/20 py-3 text-white placeholder-transparent
                               focus:outline-none focus:border-yellow-400 transition"
                    >
                    <label class="absolute left-0 top-3 text-white/50 text-sm transition-all
                                  peer-placeholder-shown:top-3 peer-placeholder-shown:text-base peer-placeholder-shown:text-white/30
                                  peer-focus:-top-4 peer-focus:text-sm peer-focus:text-yellow-400
                                  peer-valid:-top-4 peer-valid:text-sm peer-valid:text-yellow-400">
                        Email Address
                    </label>
                </div>

                <!-- Image URL -->
                <div class="relative">
                    <input
                        required
                        name="image"
                        type="text"
                        value="<%= users.image %>"
                        placeholder="Profile Image URL"
                        class="peer w-full bg-transparent border-b border-white/20 py-3 text-white placeholder-transparent
                               focus:outline-none focus:border-yellow-400 transition"
                    >
                    <label class="absolute left-0 top-3 text-white/50 text-sm transition-all
                                  peer-placeholder-shown:top-3 peer-placeholder-shown:text-base peer-placeholder-shown:text-white/30
                                  peer-focus:-top-4 peer-focus:text-sm peer-focus:text-yellow-400
                                  peer-valid:-top-4 peer-valid:text-sm peer-valid:text-yellow-400">
                        Profile Image URL
                    </label>
                </div>

                <button
                    type="submit"
                    class="w-full mt-6 py-3 rounded-xl font-medium text-lg text-black
                           bg-gradient-to-r from-yellow-400 via-yellow-500 to-amber-500
                           hover:brightness-110 transition
                           active:scale-[0.97] shadow-xl shadow-yellow-500/30"
                >
                    Update User
                </button>

            </form>

        </div>
    </div>

</body>
</html>
